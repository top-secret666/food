# Google OAuth (optional — enables Google login in Keycloak)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/rgr

# Security
REQUIRE_EMAIL_VERIFIED=true

# CORS (comma-separated origins for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Service URLs (for local mvn spring-boot:run)
USER_SERVICE_URL=http://localhost:8084
RESTAURANT_SERVICE_URL=http://localhost:8081
ORDER_SERVICE_URL=http://localhost:8082
